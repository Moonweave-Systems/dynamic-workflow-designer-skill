{
  "schema_version": "0.5",
  "plan_id": "v105-final-adoption",
  "created_by": "keelplane",
  "source_prompt": "한번더 리뷰하고 전체 수행 계획 문서화 하자",
  "activation": {
    "decision": "activate",
    "matched_thresholds": [
      "downstream-consumer",
      "resumable-handoffs",
      "adversarial-verification"
    ],
    "downgrade_target": null,
    "reason": "The V105 final bundle adoption spans verifier semantics, evidence discovery, capture, native pack references, lowering contracts, and paired evaluation, so it needs a resumable multi-phase plan with explicit evidence gates."
  },
  "objective": "Adopt the keelplane-v105-final direction as an ordered Keelplane execution roadmap centered on semantic safety, evidence custody, decision plus assurance, and measured native-profile value.",
  "surfaces": [
    {
      "id": "current-repo",
      "kind": "repo",
      "locator": ".",
      "access_mode": "write-proposed"
    },
    {
      "id": "v105-final-bundle",
      "kind": "artifact",
      "locator": "keelplane-v105-final/",
      "access_mode": "read-only"
    },
    {
      "id": "workflow-schema",
      "kind": "document",
      "locator": "references/workflow-plan-schema.md",
      "access_mode": "read-only"
    }
  ],
  "assumptions": [
    {
      "claim": "The V105 final bundle is a design and reference-pack source, not an upstream patch to copy wholesale.",
      "verification": "Keep each adoption phase gated by repo-native fixtures and command outputs."
    },
    {
      "claim": "The current repo should keep core/reference runtime scripts stdlib-only.",
      "verification": "Block new runtime dependencies unless explicitly approved and isolated."
    },
    {
      "claim": "V105/V106 existing verifier fixtures are the safest trust anchor for the first adoption slice.",
      "verification": "Run V105 and V106 self-tests after semantic-safety changes."
    }
  ],
  "patterns": [
    "Sequential",
    "Pipeline",
    "Adversarial Verify",
    "Human Gate",
    "Resume And Cache"
  ],
  "phases": [
    {
      "id": "semantic-safety",
      "name": "Semantic Safety Contract",
      "entry_criteria": [
        "V105 final bundle has been reviewed",
        "Current V105 and V106 verifier fixtures are available"
      ],
      "exit_criteria": [
        "Required claim without evaluator yields inconclusive",
        "Decision and assurance are distinct in the verifier/report path",
        "Changed-tier contract passes"
      ],
      "depends_on": [],
      "worker_ids": [
        "semantic-safety-worker"
      ],
      "outputs": [
        "semantic-safety-receipt"
      ]
    },
    {
      "id": "safe-discovery",
      "name": "Safe Discovery Contract",
      "entry_criteria": [
        "semantic-safety-receipt is verified"
      ],
      "exit_criteria": [
        "Path containment and unsafe file fixtures fail closed",
        "Discovery defaults to metadata-only streaming hashes"
      ],
      "depends_on": [
        "semantic-safety"
      ],
      "worker_ids": [
        "discovery-worker"
      ],
      "outputs": [
        "safe-discovery-receipt"
      ]
    },
    {
      "id": "evidence-manifest",
      "name": "Evidence Manifest V1 And A1 Capture",
      "entry_criteria": [
        "safe-discovery-receipt is verified"
      ],
      "exit_criteria": [
        "Manifest, ledger, seal, and tamper fixtures pass",
        "Report skeleton separates decision and assurance"
      ],
      "depends_on": [
        "safe-discovery"
      ],
      "worker_ids": [
        "evidence-worker"
      ],
      "outputs": [
        "evidence-manifest-receipt"
      ]
    },
    {
      "id": "reference-native-pack",
      "name": "Reference Native Pack",
      "entry_criteria": [
        "evidence-manifest-receipt is verified"
      ],
      "exit_criteria": [
        "Reference packs validate structurally",
        "Agent outputs remain self-reported by contract",
        "No runtime integration or productivity claim is introduced"
      ],
      "depends_on": [
        "evidence-manifest"
      ],
      "worker_ids": [
        "native-pack-worker",
        "documentation-worker"
      ],
      "outputs": [
        "native-pack-receipt",
        "draft-adoption-docs"
      ]
    },
    {
      "id": "native-lowering",
      "name": "Native Lowering Contracts",
      "entry_criteria": [
        "native-pack-receipt is verified"
      ],
      "exit_criteria": [
        "Capability reports classify exact, approximated, omitted, and unsupported controls",
        "Unsupported critical controls block lowering"
      ],
      "depends_on": [
        "reference-native-pack"
      ],
      "worker_ids": [
        "lowering-worker"
      ],
      "outputs": [
        "native-lowering-receipt"
      ]
    },
    {
      "id": "paired-dogfood",
      "name": "Paired Dogfood Evaluation",
      "entry_criteria": [
        "native-lowering-receipt is verified"
      ],
      "exit_criteria": [
        "Direct and profile runs are paired and recorded",
        "No productivity or quality claim is made beyond the evidence",
        "Activation recommendations are updated from results"
      ],
      "depends_on": [
        "native-lowering"
      ],
      "worker_ids": [
        "evaluation-worker",
        "documentation-worker"
      ],
      "outputs": [
        "paired-evaluation-receipt",
        "final-adoption-docs"
      ]
    }
  ],
  "workers": [
    {
      "id": "semantic-safety-worker",
      "role": "Verifier semantics implementer",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": true,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "network",
          "external-message"
        ]
      },
      "forbidden_actions": [
        "add runtime dependencies",
        "import native agent pack",
        "claim productivity improvement",
        "rewrite git history"
      ],
      "context_budget": {
        "max_files": 16,
        "max_tokens": 16000,
        "must_include": [
          "keelplane/verify/engine.py",
          "docs/v105-verify-wedge-spec.md",
          "docs/v106-multi-wave-spec.md"
        ],
        "must_exclude": [
          "secrets",
          "global config"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "V105 final direction",
          "current verifier fixtures",
          "repository path"
        ],
        "required_output_schema": "semantic-safety-receipt",
        "stop_conditions": [
          "missing evaluator can still pass",
          "changed-tier contract cannot run",
          "runtime dependency appears necessary"
        ]
      },
      "ownership": [
        "verifier semantics",
        "false-pass fixtures",
        "semantic-safety docs"
      ]
    },
    {
      "id": "discovery-worker",
      "role": "Safe evidence discovery implementer",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": true,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "network",
          "external-message"
        ]
      },
      "forbidden_actions": [
        "capture full content by default",
        "follow symlinks",
        "read secrets",
        "add non-stdlib runtime dependency"
      ],
      "context_budget": {
        "max_files": 18,
        "max_tokens": 18000,
        "must_include": [
          "keelplane/verify/adapters/generic.py",
          "keelplane-v105-final/docs/threat-model-v1.md"
        ],
        "must_exclude": [
          "secret files",
          "external network sources"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "semantic-safety-receipt",
          "threat-model path rules"
        ],
        "required_output_schema": "safe-discovery-receipt",
        "stop_conditions": [
          "unsafe path can satisfy policy",
          "file size limits are unbounded"
        ]
      },
      "ownership": [
        "generic adapter discovery",
        "path and size fixtures"
      ]
    },
    {
      "id": "evidence-worker",
      "role": "Evidence manifest and seal implementer",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": true,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "network",
          "external-message"
        ]
      },
      "forbidden_actions": [
        "execute artifact-provided commands",
        "invent signatures",
        "claim provider identity",
        "add dashboard"
      ],
      "context_budget": {
        "max_files": 24,
        "max_tokens": 22000,
        "must_include": [
          "keelplane-v105-final/tools/capture_local.py",
          "keelplane-v105-final/tools/verify_seal.py",
          "keelplane-v105-final/docs/evidence-protocol-v1.md"
        ],
        "must_exclude": [
          "private keys",
          "environment dumps"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "safe-discovery-receipt",
          "evidence protocol",
          "schema fixtures"
        ],
        "required_output_schema": "evidence-manifest-receipt",
        "stop_conditions": [
          "tamper does not invalidate seal",
          "manifest implies stronger than A1 assurance"
        ]
      },
      "ownership": [
        "manifest schemas",
        "A1 capture",
        "seal verification",
        "report skeleton"
      ]
    },
    {
      "id": "native-pack-worker",
      "role": "Reference native pack curator",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": true,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "network",
          "external-message"
        ]
      },
      "forbidden_actions": [
        "modify global config",
        "pin exact model IDs",
        "add API keys",
        "enable permission bypass",
        "claim runtime authority"
      ],
      "context_budget": {
        "max_files": 28,
        "max_tokens": 24000,
        "must_include": [
          "keelplane-v105-final/packs",
          "keelplane-v105-final/profiles",
          "keelplane-v105-final/docs/agent-team-spec-v1.md"
        ],
        "must_exclude": [
          "global user config",
          "credentials"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "evidence-manifest-receipt",
          "native pack bundle",
          "profile schemas"
        ],
        "required_output_schema": "native-pack-receipt",
        "stop_conditions": [
          "pack requires runtime integration",
          "pack changes trust semantics"
        ]
      },
      "ownership": [
        "reference profiles",
        "Codex/Claude pack assets",
        "installer validation"
      ]
    },
    {
      "id": "lowering-worker",
      "role": "Native lowering contract implementer",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": true,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "network",
          "external-message"
        ]
      },
      "forbidden_actions": [
        "treat lowering as bijection",
        "silently omit critical controls",
        "launch native agents"
      ],
      "context_budget": {
        "max_files": 20,
        "max_tokens": 20000,
        "must_include": [
          "keelplane-v105-final/examples/artifacts/run-contract.example.json",
          "keelplane-v105-final/examples/artifacts/compile-report.example.json"
        ],
        "must_exclude": [
          "native session private state"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "native-pack-receipt",
          "evidence-manifest-receipt"
        ],
        "required_output_schema": "native-lowering-receipt",
        "stop_conditions": [
          "unsupported critical control is not blocked",
          "capability source is missing"
        ]
      },
      "ownership": [
        "capability report fixtures",
        "run contract fixtures"
      ]
    },
    {
      "id": "evaluation-worker",
      "role": "Paired dogfood evaluator",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": true,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "network",
          "external-message",
          "write"
        ]
      },
      "forbidden_actions": [
        "publish superiority claims",
        "cherry-pick traces",
        "count inconclusive as pass"
      ],
      "context_budget": {
        "max_files": 22,
        "max_tokens": 20000,
        "must_include": [
          "keelplane-v105-final/docs/evaluation-spec-v1.md"
        ],
        "must_exclude": [
          "unfrozen task variants"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "native-lowering-receipt",
          "frozen paired task corpus"
        ],
        "required_output_schema": "paired-evaluation-receipt",
        "stop_conditions": [
          "baseline and profile arms are not comparable",
          "raw failures are missing"
        ]
      },
      "ownership": [
        "paired evaluation fixtures",
        "activation recommendation"
      ]
    },
    {
      "id": "documentation-worker",
      "role": "Adoption documentation writer",
      "tool_permissions": {
        "read": true,
        "write": true,
        "shell": false,
        "network": false,
        "mcp_connectors": [],
        "requires_escalation_for": [
          "external-message",
          "write"
        ]
      },
      "forbidden_actions": [
        "document unrun steps as complete",
        "claim productivity improvement without evaluation",
        "hide limitations"
      ],
      "context_budget": {
        "max_files": 18,
        "max_tokens": 18000,
        "must_include": [
          "phase receipts",
          "risk register",
          "decision records"
        ],
        "must_exclude": [
          "secrets",
          "private session text"
        ]
      },
      "prompt_contract": {
        "inputs": [
          "verified phase receipts",
          "V105 final bundle review"
        ],
        "required_output_schema": "final-adoption-docs",
        "stop_conditions": [
          "evidence for a claim is missing",
          "docs and JSON plan disagree"
        ]
      },
      "ownership": [
        "adoption docs",
        "gap ledger",
        "risk register"
      ]
    }
  ],
  "handoffs": [
    {
      "from_phase": "semantic-safety",
      "to_phase": "safe-discovery",
      "artifact": "semantic-safety-receipt",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "fixture_ids",
          "expected_decisions",
          "actual_decisions",
          "verification_commands"
        ],
        "validation_command": "python -m json.tool semantic-safety-receipt.json"
      }
    },
    {
      "from_phase": "safe-discovery",
      "to_phase": "evidence-manifest",
      "artifact": "safe-discovery-receipt",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "rejection_matrix",
          "limits",
          "safe_examples",
          "verification_commands"
        ],
        "validation_command": "python -m json.tool safe-discovery-receipt.json"
      }
    },
    {
      "from_phase": "evidence-manifest",
      "to_phase": "reference-native-pack",
      "artifact": "evidence-manifest-receipt",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "manifest_examples",
          "seal_examples",
          "tamper_results",
          "assurance_limitations"
        ],
        "validation_command": "python -m json.tool evidence-manifest-receipt.json"
      }
    },
    {
      "from_phase": "reference-native-pack",
      "to_phase": "native-lowering",
      "artifact": "native-pack-receipt",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "profile_inventory",
          "pack_validation",
          "installer_receipt",
          "non_runtime_boundary"
        ],
        "validation_command": "python -m json.tool native-pack-receipt.json"
      }
    },
    {
      "from_phase": "native-lowering",
      "to_phase": "paired-dogfood",
      "artifact": "native-lowering-receipt",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "capability_reports",
          "run_contracts",
          "unsupported_critical_results"
        ],
        "validation_command": "python -m json.tool native-lowering-receipt.json"
      }
    }
  ],
  "parallelism": {
    "shape": "hybrid",
    "concurrency_cap": 2,
    "fan_in_rule": "Early trust phases are sequential; after evidence-manifest is verified, reference-pack documentation can draft in parallel with pack validation, but final synthesis waits for paired dogfood receipts.",
    "barriers": [
      "semantic-safety must pass before discovery",
      "safe-discovery must pass before manifest and seal work",
      "evidence-manifest must pass before native packs",
      "native-lowering must exist before paired dogfood claims"
    ]
  },
  "verification": [
    {
      "claim_or_output": "Required claims without evaluators cannot pass.",
      "falsifier": "A fixture with a required claim and no evaluator produces pass or verified.",
      "evidence_required": [
        "semantic-safety-receipt",
        "changed-tier command output"
      ]
    },
    {
      "claim_or_output": "Evidence discovery is safe enough to feed manifests.",
      "falsifier": "Path traversal, symlink, special-file, collision, or oversize evidence is accepted as trusted evidence.",
      "evidence_required": [
        "safe-discovery-receipt",
        "unsafe-path fixture results"
      ]
    },
    {
      "claim_or_output": "A1 local capture is tamper-evident but not overclaimed.",
      "falsifier": "A changed sealed file still verifies, or the report claims provider identity.",
      "evidence_required": [
        "evidence-manifest-receipt",
        "seal verification output"
      ]
    },
    {
      "claim_or_output": "Native packs remain reference consumers of evidence policy.",
      "falsifier": "A pack claims pass, writes authoritative seal files, pins provider/model secrets, or enables bypass permissions by default.",
      "evidence_required": [
        "native-pack-receipt",
        "pack structural validation"
      ]
    },
    {
      "claim_or_output": "Productivity and quality claims are supported only after paired evaluation.",
      "falsifier": "Docs or reports claim superiority before paired dogfood evidence exists.",
      "evidence_required": [
        "paired-evaluation-receipt",
        "final-adoption-docs"
      ]
    }
  ],
  "risk_gates": [
    {
      "trigger": "write action requested",
      "safe_default": "stop before writing and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "shell action requested",
      "safe_default": "stop before shell use and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "network action requested",
      "safe_default": "stop before network access and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "external message action requested",
      "safe_default": "stop before external message and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "required claim or adversarial item lacks evaluator",
      "safe_default": "stop before policy override and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "path traversal, symlink, special file, collision, or oversize evidence is encountered",
      "safe_default": "stop before trusting unsafe evidence and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "new runtime dependency appears necessary",
      "safe_default": "stop before adding dependency and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "network, deployment, database, secret, paid API, external messaging, destructive command, or history rewrite is requested",
      "safe_default": "stop before external side effect and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "native pack or documentation implies productivity, quality, or runtime authority before paired evaluation",
      "safe_default": "stop before publishing benefit claim and ask for approval",
      "requires_user_approval": true
    }
  ],
  "budget": {
    "max_agents": 7,
    "max_rounds": 6,
    "max_retries": 1,
    "time_box": "six PR-sized phases; first slice should fit in one focused implementation session",
    "file_touch_limit": "first slice limited to verifier fixtures, verifier code, and one decision/spec doc"
  },
  "resume": {
    "cacheable_outputs": [
      "semantic-safety-receipt",
      "safe-discovery-receipt",
      "evidence-manifest-receipt",
      "native-pack-receipt",
      "native-lowering-receipt",
      "paired-evaluation-receipt"
    ],
    "invalidators": [
      "verifier semantics change",
      "generic discovery behavior change",
      "schema version change",
      "native harness pack format change",
      "paired task corpus changes"
    ],
    "restart_points": [
      "semantic-safety",
      "safe-discovery",
      "evidence-manifest",
      "reference-native-pack",
      "native-lowering",
      "paired-dogfood"
    ]
  },
  "execution_path": {
    "mode": "subagent-plan",
    "consumer": "codex-agent",
    "first_slice": {
      "instruction": "Add regression coverage proving that a required claim or adversarial item with no evaluator cannot pass, then make the smallest verifier change so the result is inconclusive with explicit assurance rather than pass.",
      "inputs": [
        "repository path",
        "docs/v105-verify-wedge-spec.md",
        "docs/v106-multi-wave-spec.md",
        "keelplane-v105-final/docs/product-direction-v105.md",
        "keelplane-v105-final/docs/evidence-protocol-v1.md",
        "keelplane-v105-final/docs/upstream-gap-map.md"
      ],
      "expected_output": "semantic-safety-receipt with failing-before/passing-after evidence",
      "completion_check": "missing evaluator cases produce inconclusive and changed-tier contract passes",
      "forbidden_actions": [
        "import native agent pack",
        "add dashboard",
        "add runtime dependency",
        "claim productivity improvement",
        "rewrite git history"
      ]
    },
    "first_wave": {
      "id": "wave-1-semantic-safety",
      "concurrency_cap": 1,
      "entry_gate": "V105 final bundle review complete and current V105/V106 verifier fixtures available",
      "exit_gate": "semantic-safety receipt verified with missing evaluator returning inconclusive",
      "fan_in": "single verifier semantics slice must finish before any discovery or manifest phase starts",
      "slices": [
        {
          "id": "semantic-false-pass-fixture",
          "instruction": "Create or identify a fixture where a required claim or adversarial item lacks a real evaluator and must not pass.",
          "inputs": [
            "repository path",
            "keelplane/verify/engine.py",
            "fixtures"
          ],
          "expected_output": "fixture that fails before the verifier semantic fix and expects inconclusive",
          "completion_check": "fixture expectation is explicit and cannot be satisfied by path existence alone",
          "forbidden_actions": [
            "native pack work",
            "dashboard work",
            "dependency installation"
          ]
        },
        {
          "id": "semantic-verifier-fix",
          "instruction": "Make the smallest verifier change so missing evaluator states become inconclusive and decision remains separate from assurance.",
          "inputs": [
            "semantic false-pass fixture",
            "current verifier implementation"
          ],
          "expected_output": "verifier semantic fix plus receipt of changed-tier contract output",
          "completion_check": "V105/V106 tests and changed-tier contract pass",
          "forbidden_actions": [
            "broad refactor",
            "agent pack import",
            "productivity claims"
          ]
        }
      ]
    },
    "waves": [
      {
        "id": "wave-2-safe-discovery",
        "depends_on": [
          "wave-1-semantic-safety"
        ],
        "concurrency_cap": 1,
        "entry_gate": "receipt from wave-1-semantic-safety verified and no semantic false-pass remains",
        "slices": [
          "safe-discovery-contract"
        ],
        "exit_gate": "safe discovery receipt verified"
      },
      {
        "id": "wave-3-evidence-manifest",
        "depends_on": [
          "wave-2-safe-discovery"
        ],
        "concurrency_cap": 1,
        "entry_gate": "receipt from wave-2-safe-discovery verified with unsafe evidence rejected",
        "slices": [
          "evidence-manifest-a1-capture"
        ],
        "exit_gate": "manifest, ledger, seal, and report skeleton receipt verified"
      },
      {
        "id": "wave-4-reference-pack-and-docs",
        "depends_on": [
          "wave-3-evidence-manifest"
        ],
        "concurrency_cap": 2,
        "entry_gate": "receipt from wave-3-evidence-manifest verified with A1 limitations explicit",
        "slices": [
          "reference-native-pack",
          "draft-adoption-docs"
        ],
        "exit_gate": "reference pack and draft docs preserve non-runtime trust boundary"
      },
